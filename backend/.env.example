# MacroLens backend 환경변수 템플릿. 복사해서 .env 로 만들고 값 채우기. (.env 는 커밋 금지)
# LLM (기본 provider=solar)
LLM_PROVIDER=solar
SOLAR_API_KEY=
ANTHROPIC_API_KEY=
# 데이터 소스 (RAG는 키 불필요)
FRED_API_KEY=
ECOS_API_KEY=
FMP_API_KEY=
# 경로 (그대로 두기)
RAG_CORPUS_DIR=../rag_corpus
CHROMA_DIR=./.chroma
SQLITE_PATH=./macrolens.db
# RAG 가중치 기본값
W_CAUSAL=0.5
W_HISTORICAL=0.5
